      "additionalProperties": false,
      "properties": {
        "wallet": {
          "type": "string"
        }
      },
      "required": [
        "wallet"
      ],
      "type": "object"
    },
    "outputSchema": {
      "additionalProperties": false,
      "properties": {
        "addresses": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "address": {
                "type": "string"
              },
              "branch": {
                "maximum": 4294967295,
                "minimum": 0,
                "type": "integer"
              },
              "created_at": {
                "type": "string"
              },
              "index": {
                "maximum": 4294967295,
                "minimum": 0,
                "type": "integer"
              },
              "ref": {
                "type": "string"
              }
            },
            "required": [
              "ref",
              "branch",
              "index",
              "address",
              "created_at"
            ],
            "type": "object"
          },
          "type": [
            "null",
            "array"
          ]
        },
        "network": {
          "type": "string"
        },
        "wallet": {
          "type": "string"
        }
      },
      "required": [
        "wallet",
        "network",
        "addresses"
      ],
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": true
    }
  },
  {
    "name": "address_new",
    "description": "Derive and record the NEXT receive address for a wallet (a fresh invoice address to hand a counterparty). Derivation is from the stored xpub — no passphrase, no signing. Set 'change':true for an internal change address instead (rarely needed). Returns the ref (wallet/branch/index), the bech32 address, and the full BIP-84 path. This is the agent's sanctioned way to get a new address; raw key derivation and wallet creation are NOT exposed.",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "change": {
          "type": "boolean"
        },
        "wallet": {
          "type": "string"
        }
      },
      "required": [
        "wallet"
      ],
      "type": "object"
    },
    "outputSchema": {
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string"
        },
        "branch": {
          "maximum": 4294967295,
          "minimum": 0,
          "type": "integer"
        },
        "index": {
          "maximum": 4294967295,
          "minimum": 0,
          "type": "integer"
        },
        "path": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "wallet": {
          "type": "string"
        }
      },
      "required": [
        "wallet",
        "ref",
        "branch",
        "index",
        "address",
        "path"
      ],
      "type": "object"
    },
    "annotations": {
      "destructiveHint": true
    }
  },
  {
