  {
    "name": "policy_check",
    "description": "Dry-run evaluate a hypothetical send against the active policy WITHOUT reserving budget or signing anything: would this recipient + amount be allowed? Returns allowed:true, or allowed:false with the dotted denial code (policy.denied.*) and reason. 'to' and 'amount' are required; 'fee_rate'/'fee_sat' refine the estimate. Read-only (no reservation is written).",
    "inputSchema": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "description": "amount to check, a decimal BTC string or an integer-sat string",
          "type": "string"
        },
        "fee_rate": {
          "description": "assumed fee rate in sat/vByte (optional)",
          "type": "integer"
        },
        "fee_sat": {
          "description": "assumed absolute fee in sats (optional)",
          "type": "integer"
        },
        "to": {
          "description": "recipient Bitcoin address for the active network",
          "type": "string"
        }
      },
      "required": [
        "to",
        "amount"
      ],
      "type": "object"
    },
    "outputSchema": {
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "code": {
          "type": "string"
        },
        "data": {
          "additionalProperties": true,
          "type": "object"
        },
        "reason": {
          "type": "string"
        },
        "retry_after": {
          "type": "string"
        }
      },
      "required": [
        "allowed"
      ],
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": true
    }
  },
